# WHC shared-hosting Apache configuration for the generated static site.
# Upload this file with the contents of .output/public.

Options -Indexes
DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Canonical host and HTTPS in one method-preserving redirect.
  RewriteCond %{HTTP_HOST} ^(?:www\.)?affinitycreative\.ca$ [NC]
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.affinitycreative\.ca$ [NC]
  RewriteRule ^ https://affinitycreative.ca%{REQUEST_URI} [R=308,L,NE]

  # PHP endpoints remain executable and are never routed to static HTML.
  RewriteRule ^api/ - [L]

  # Directory-style URLs for generated pages.
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.+[^/])$ %{REQUEST_URI}/ [R=301,L]
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set X-XSS-Protection "0"

  <FilesMatch "\.(css|js|webp|avif|png|jpg|jpeg|svg|woff2)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

AddType image/webp .webp
AddType image/avif .avif
AddType image/svg+xml .svg
AddType application/javascript .js
AddType text/css .css

# Protect sensitive configuration and development files.
<FilesMatch "^(\.env.*|config\.php|config\.example\.php|quote-config\.php|quote-config\.example\.php|composer\.(json|lock)|package(-lock)?\.json|pnpm-lock\.yaml|tsconfig\.json|nuxt\.config\.ts)$">
  Require all denied
</FilesMatch>

# Protect accidentally uploaded backup, database and archive files.
<FilesMatch "(?i)\.(zip|bak|old|backup|sql|tar|gz|tgz)$">
  Require all denied
</FilesMatch>

ErrorDocument 404 /404.html

# ==================================================
# AFFINITY CREATIVE CACHE CONTROL
# HTML must always check for the latest version
# ==================================================

<IfModule mod_headers.c>

    # Never keep an old page without checking the server
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # JSON and deployment metadata may change
    <FilesMatch "\.(json|xml)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>

    # Cache styles, scripts, fonts and images for one hour
    <FilesMatch "\.(css|js|mjs|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf)$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>

</IfModule>
