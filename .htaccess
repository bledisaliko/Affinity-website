# WHC shared-hosting Apache configuration for the generated static site.
# Upload this file with the contents of .output/public.

Options -Indexes
DirectoryIndex index.html index.php

FileETag None

<IfModule LiteSpeed>
  CacheDisable public /
  CacheDisable private /
  CacheLookup public off
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Canonical host and HTTPS in one method-preserving redirect.
  RewriteCond %{HTTP_HOST} ^(?:www\.)?affinitycreative\.ca$ [NC]
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.affinitycreative\.ca$ [NC]
  RewriteRule ^ https://affinitycreative.ca%{REQUEST_URI} [R=308,L,NE]

  # PHP endpoints remain executable and are never routed to static HTML.
  RewriteRule ^api/ - [L]

  # Directory-style URLs for generated pages.
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.+[^/])$ %{REQUEST_URI}/ [R=301,L]
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 0 seconds"

  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType text/javascript "access plus 0 seconds"
  ExpiresByType application/json "access plus 0 seconds"
  ExpiresByType application/xml "access plus 0 seconds"
  ExpiresByType text/xml "access plus 0 seconds"
  ExpiresByType image/avif "access plus 0 seconds"
  ExpiresByType image/webp "access plus 0 seconds"
  ExpiresByType image/png "access plus 0 seconds"
  ExpiresByType image/jpeg "access plus 0 seconds"
  ExpiresByType image/gif "access plus 0 seconds"
  ExpiresByType image/svg+xml "access plus 0 seconds"
  ExpiresByType image/x-icon "access plus 0 seconds"
  ExpiresByType font/woff "access plus 0 seconds"
  ExpiresByType font/woff2 "access plus 0 seconds"
  ExpiresByType font/ttf "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set X-XSS-Protection "0"

  <FilesMatch "\.(html?|css|js|mjs|json|xml|txt|png|jpe?g|gif|svg|webp|avif|ico|woff2?|ttf|otf)$">
    Header unset Cache-Control
    Header always unset Cache-Control
    Header unset Expires
    Header always unset Expires
    Header unset ETag
    Header always unset ETag
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0, proxy-revalidate"
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0, proxy-revalidate"
    Header set Pragma "no-cache"
    Header always set Pragma "no-cache"
    Header set Expires "0"
    Header always set Expires "0"
  </FilesMatch>
</IfModule>

AddType image/webp .webp
AddType image/avif .avif
AddType image/svg+xml .svg
AddType application/javascript .js
AddType text/css .css

# Protect sensitive configuration and development files.
<FilesMatch "^(\.env.*|config\.php|config\.example\.php|quote-config\.php|quote-config\.example\.php|composer\.(json|lock)|package(-lock)?\.json|pnpm-lock\.yaml|tsconfig\.json|nuxt\.config\.ts)$">
  Require all denied
</FilesMatch>

# Protect accidentally uploaded backup, database and archive files.
<FilesMatch "(?i)\.(zip|bak|old|backup|sql|tar|gz|tgz)$">
  Require all denied
</FilesMatch>

ErrorDocument 404 /404.html

