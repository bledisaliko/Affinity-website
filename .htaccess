# WHC shared-hosting Apache configuration for the generated static site.
# Upload this file with the contents of .output/public.

Options -Indexes
DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Canonical host and HTTPS in one method-preserving redirect.
  RewriteCond %{HTTP_HOST} ^(?:www\.)?affinitycreative\.ca$ [NC]
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.affinitycreative\.ca$ [NC]
  RewriteRule ^ https://affinitycreative.ca%{REQUEST_URI} [R=308,L,NE]

  # PHP endpoints remain executable and are never routed to static HTML.
  RewriteRule ^api/ - [L]

  # Directory-style URLs for generated pages.
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.+[^/])$ %{REQUEST_URI}/ [R=301,L]
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set X-XSS-Protection "0"

  <FilesMatch "\.(css|js|webp|avif|png|jpg|jpeg|svg|woff2)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

AddType image/webp .webp
AddType image/avif .avif
AddType image/svg+xml .svg
AddType application/javascript .js
AddType text/css .css

# Protect sensitive configuration and development files.
<FilesMatch "^(\.env.*|config\.php|config\.example\.php|quote-config\.php|quote-config\.example\.php|composer\.(json|lock)|package(-lock)?\.json|pnpm-lock\.yaml|tsconfig\.json|nuxt\.config\.ts)$">
  Require all denied
</FilesMatch>

# Protect accidentally uploaded backup, database and archive files.
<FilesMatch "(?i)\.(zip|bak|old|backup|sql|tar|gz|tgz)$">
  Require all denied
</FilesMatch>

ErrorDocument 404 /404.html
# =========================================================
# TEMPORARY ZERO-CACHE MODE — AFFINITY CREATIVE
# Use while the website is being actively developed
# =========================================================

<IfModule LiteSpeed>
    CacheLookup off
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 0 seconds"

    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType text/css "access plus 0 seconds"
    ExpiresByType application/javascript "access plus 0 seconds"
    ExpiresByType text/javascript "access plus 0 seconds"
    ExpiresByType application/json "access plus 0 seconds"
    ExpiresByType image/jpeg "access plus 0 seconds"
    ExpiresByType image/png "access plus 0 seconds"
    ExpiresByType image/webp "access plus 0 seconds"
    ExpiresByType image/svg+xml "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(html?|css|js|mjs|json|xml|png|jpe?g|gif|svg|webp|ico|woff|woff2|ttf)$">
        Header always unset Cache-Control
        Header always unset Expires
        Header always unset ETag

        Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0, proxy-revalidate"
        Header always set Pragma "no-cache"
        Header always set Expires "0"
    </FilesMatch>
</IfModule>

FileETag None
